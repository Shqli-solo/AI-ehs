# EHS 智能安保决策中台 - 环境变量配置
# 复制此文件为 .env 并修改相应值
# cp .env.example .env

# ============================================
# 数据库配置 (PostgreSQL + pgvector)
# ============================================
POSTGRES_DB=ehs
POSTGRES_USER=ehs
POSTGRES_PASSWORD=ehs123
# PostgreSQL 连接字符串（本地开发）
DATABASE_URL=postgresql://ehs:ehs123@localhost:5432/ehs

# ============================================
# MinIO 配置
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# JWT 认证
# ============================================
JWT_SECRET=ehs-jwt-secret-change-in-production
# 开发环境关闭认证，生产环境设为 true
AUTH_ENABLED=false

# ============================================
# 日志
# ============================================
LOG_LEVEL=INFO
