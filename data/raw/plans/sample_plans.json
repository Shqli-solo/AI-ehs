    "id": "PLAN-0004",
    "title": "安防入侵应急处置预案",
    "event_type": "intrusion",
    "risk_level": "HIGH",
    "content": "本预案适用于非法入侵公司场所的应急处置。入侵事件可能威胁人员安全和公司财产安全。预案包括入侵检测、警戒响应、人员管控、报警处置、事后调查等内容。",
    "actions": [
      {
        "step": 1,
        "action": "确认入侵警报，通过监控系统定位入侵者位置",
        "role": "监控中心",
        "timeout_seconds": 60
      },
      {
        "step": 2,
        "action": "启动门禁系统封锁相关区域，防止入侵者扩散",
        "role": "安保主管",
        "timeout_seconds": 120
      },
      {
        "step": 3,
        "action": "派遣安保人员前往现场，保持安全距离进行劝阻",
        "role": "安保人员",
        "timeout_seconds": 300
      },
      {
        "step": 4,
        "action": "如入侵者拒不配合或有暴力行为，立即拨打 110 报警",
        "role": "安保主管",
        "timeout_seconds": 60
      },
      {
        "step": 5,
        "action": "保护现场，配合警方调查，保存监控录像证据",
        "role": "安全负责人",
        "timeout_seconds": 7200
      }
    ],
    "contacts": [
      {
        "name": "郑华",
        "role": "安保部经理",
        "phone": "138-0004-0001"
      },
      {
        "name": "钱伟",
        "role": "监控中心主管",
        "phone": "138-0004-0002"
      }
    ],
    "resources": ["对讲机", "执法记录仪", "防暴盾牌", "监控录像系统"],
    "training_requirements": "安保人员需持证上岗，每季度进行一次入侵处置演练",
    "last_updated": "2026-01-25T09:00:00Z",
    "version": "1.8.0"
