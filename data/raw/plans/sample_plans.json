  {
    "id": "PLAN-0005",
    "title": "电力故障应急处置预案",
    "event_type": "power_failure",
    "risk_level": "MEDIUM",
    "content": "本预案适用于公司突发停电事件的应急处置。电力故障可能导致生产中断、数据丢失、设备损坏等后果。预案包括故障检测、UPS 切换、设备保护、应急供电、恢复送电等内容。",
    "actions": [
      {
        "step": 1,
        "action": "确认停电范围，检查是内部故障还是外部电网停电",
        "role": "值班电工",
        "timeout_seconds": 120
      },
      {
        "step": 2,
        "action": "确认 UPS 系统自动切换成功，检查负载设备运行状态",
        "role": "设备维护人员",
        "timeout_seconds": 300
      },
      {
        "step": 3,
        "action": "关闭非关键设备电源，延长 UPS 供电时间",
        "role": "系统管理员",
        "timeout_seconds": 600
      },
      {
        "step": 4,
        "action": "启动柴油发电机，恢复关键区域供电",
        "role": "电工班",
        "timeout_seconds": 900
      },
      {
        "step": 5,
        "action": "市电恢复后，逐步切换回市电供电，检查设备是否正常",
        "role": "值班电工",
        "timeout_seconds": 1800
      }
    ],
    "contacts": [
      {
        "name": "冯杰",
        "role": "电力主管",
        "phone": "138-0005-0001"
      },
      {
        "name": "陈静",
        "role": "设备部经理",
        "phone": "138-0005-0002"
      }
    ],
    "resources": ["UPS 系统", "柴油发电机", "万用表", "应急照明", "绝缘工具"],
    "training_requirements": "电工需持有特种作业证，每半年进行一次停电应急演练",
    "last_updated": "2026-02-28T11:00:00Z",
    "version": "2.0.0"
