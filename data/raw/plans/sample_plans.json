[
  {
    "id": "PLAN-0001",
    "title": "火灾事故专项应急预案",
    "event_type": "fire",
    "risk_level": "CRITICAL",
    "content": "本预案适用于公司范围内所有火灾事故的应急处置。火灾事故发生时，应立即启动本预案，组织人员疏散，进行初期火灾扑救，并报告消防部门。预案包括火灾预警、应急响应、人员疏散、火灾扑救、事后恢复等内容。",
    "actions": [
      {
        "step": 1,
        "action": "发现火情后立即按下最近的手动火灾报警按钮，并大声呼救提醒周围人员",
        "role": "第一发现人",
        "timeout_seconds": 30
      },
      {
        "step": 2,
        "action": "立即拨打 119 火警电话，报告火灾地点、火势大小、有无人员被困",
        "role": "值班人员",
        "timeout_seconds": 60
      },
      {
        "step": 3,
        "action": "启动应急广播系统，通知所有人员按疏散路线有序撤离",
        "role": "控制中心",
        "timeout_seconds": 120
      },
      {
        "step": 4,
        "action": "组织人员使用灭火器、消防栓进行初期火灾扑救",
        "role": "义务消防队",
        "timeout_seconds": 300
      },
      {
        "step": 5,
        "action": "在安全集合点清点人数，确认有无人员被困",
        "role": "各部门负责人",
        "timeout_seconds": 600
      }
    ],
    "contacts": [
      {
        "name": "张伟",
        "role": "安全总监",
        "phone": "138-0001-0001"
      },
      {
        "name": "李强",
        "role": "消防主管",
        "phone": "138-0001-0002"
      },
      {
        "name": "王芳",
        "role": "医疗救护负责人",
        "phone": "138-0001-0003"
      }
    ],
    "resources": ["干粉灭火器", "二氧化碳灭火器", "消防水带", "防烟面罩", "急救箱", "应急照明灯"],
    "training_requirements": "全体员工每半年参加一次消防安全培训，义务消防队员每月进行一次灭火演练",
    "last_updated": "2026-01-15T08:00:00Z",
    "version": "2.1.0"
  },
  {
    "id": "PLAN-0002",
    "title": "可燃气体泄漏应急处置预案",
    "event_type": "gas_leak",
    "risk_level": "CRITICAL",
    "content": "本预案适用于甲烷、氢气等可燃气体泄漏事故的应急处置。气体泄漏可能引发火灾、爆炸、中毒等次生灾害，必须迅速响应。预案包括泄漏检测、警戒隔离、人员疏散、泄漏处置、环境监测等内容。",
    "actions": [
      {
        "step": 1,
        "action": "立即关闭泄漏区域的电源，禁止一切明火和可能产生火花的操作",
        "role": "第一发现人",
        "timeout_seconds": 30
      },
      {
        "step": 2,
        "action": "佩戴防毒面具，关闭泄漏源阀门，打开门窗通风",
        "role": "应急处置人员",
        "timeout_seconds": 120
      },
      {
        "step": 3,
        "action": "设置警戒区域，疏散泄漏污染区人员至上风处",
        "role": "安全员",
        "timeout_seconds": 300
      },
      {
        "step": 4,
        "action": "使用可燃气体检测仪持续监测浓度，确认是否达到爆炸下限",
        "role": "监测人员",
        "timeout_seconds": 600
      },
      {
        "step": 5,
        "action": "联系专业维修人员修复泄漏点，确认安全后恢复生产",
        "role": "设备主管",
        "timeout_seconds": 3600
      }
    ],
    "contacts": [
      {
        "name": "赵明",
        "role": "气体安全主管",
        "phone": "138-0002-0001"
      },
      {
        "name": "孙丽",
        "role": "环保监测负责人",
        "phone": "138-0002-0002"
      }
    ],
    "resources": ["防毒面具", "可燃气体检测仪", "防爆工具", "警示带", "呼吸器"],
    "training_requirements": "涉及气体操作的人员必须持有特种作业证，每季度进行一次气体泄漏应急演练",
    "last_updated": "2026-02-20T10:00:00Z",
    "version": "1.5.0"
  },
  {
    "id": "PLAN-0003",
    "title": "机房温度异常处置预案",
    "event_type": "temperature_abnormal",
    "risk_level": "MEDIUM",
    "content": "本预案适用于数据中心机房温度异常升高事件的应急处置。机房温度过高可能导致服务器宕机、数据丢失等严重后果。预案包括温度监测、空调故障处理、设备保护、紧急散热等内容。",
    "actions": [
      {
        "step": 1,
        "action": "确认温度传感器读数，检查空调运行状态",
        "role": "值班人员",
        "timeout_seconds": 60
      },
      {
        "step": 2,
        "action": "启动备用空调系统，打开机房通风窗",
        "role": "设备维护人员",
        "timeout_seconds": 300
      },
      {
        "step": 3,
        "action": "对高温区域服务器进行降频或关机保护",
        "role": "系统管理员",
        "timeout_seconds": 600
      },
      {
        "step": 4,
        "action": "联系空调维保单位进行紧急维修",
        "role": "设备主管",
        "timeout_seconds": 1800
      },
      {
        "step": 5,
        "action": "温度恢复正常后，逐步重启服务器并检查数据完整性",
        "role": "系统管理员",
        "timeout_seconds": 3600
      }
    ],
    "contacts": [
      {
        "name": "周杰",
        "role": "IT 运维主管",
        "phone": "138-0003-0001"
      },
      {
        "name": "吴敏",
        "role": "空调维保负责人",
        "phone": "138-0003-0002"
      }
    ],
    "resources": ["便携式空调", "温度记录仪", "应急电源", "服务器监控工具"],
    "training_requirements": "机房值班人员需熟悉空调系统操作，每月进行一次温度异常演练",
    "last_updated": "2026-03-10T14:00:00Z",
    "version": "1.2.0"
