{
  "name": "ehs-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "EHS 智能安保决策中台 - Monorepo 架构",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm run dev --filter @ehs/admin-console",
    "build": "pnpm run build --filter @ehs/admin-console",
    "start": "pnpm run start --filter @ehs/admin-console",
    "lint": "pnpm run lint --filter @ehs/admin-console",
    "test": "pnpm run test --filter @ehs/admin-console",
    "test:watch": "pnpm run test:watch --filter @ehs/admin-console",
    "test:coverage": "pnpm run test:coverage --filter @ehs/admin-console",
    "typecheck": "pnpm run typecheck --filter @ehs/admin-console",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:backend\"",
    "dev:backend": "cd apps/ehs-ai && poetry run uvicorn src.api.rest:app --reload --host 0.0.0.0 --port 8000",
    "dev:java": "cd apps/ehs-business && mvn spring-boot:run",
    "setup": "./scripts/setup.sh",
    "test:all": "./scripts/run-tests.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "engineStrict": true
}
